# URL base da API (Spring Boot). Usada quando VITE_USE_MOCK=false.
VITE_API_URL=http://localhost:8080

# Camada de dados:
#   true  (padrão) → mock local (localStorage). App funciona sem back-end.
#   false          → consome a API real (precisa da branch de pedidos na API
#                    + um endpoint GET /mesas, ainda não implementado).
VITE_USE_MOCK=true
